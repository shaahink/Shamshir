{
    "id":  "london-orb",
    "displayName":  "London Opening-Range Breakout",
    "enabled":  true,
    "riskProfileId":  "standard",
    "thesis":  "Price breaking the 07:00-08:00 UTC opening range at the London open continues in that direction through the session before the 16:00 daily flatten.",
    "expectedTradesPerWeek":  4,
    "expectedHoldBars":  16,
    "regimeFilter":  {
                         "allowTrending":  true,
                         "allowRanging":  true,
                         "allowHighVolatility":  true,
                         "allowLowVolatility":  true,
                         "allowUnknown":  true
                     },
    "orderEntry":  {
                        "method":  "LimitOffset",
                        "limitOffsetPips":  3.0,
                        "limitOffsetAtrFraction":  0.15,
                        "limitOrderExpiryBars":  12,
                        "maxSlippagePips":  2.0,
                        "maxSlippageSpreadMultiple":  2.0
                    },
    "positionManagement":  {
                               "stopLoss":  {
                                                "method":  "AtrMultiple",
                                                "atrMultiple":  1.5,
                                                "maxSlAtrMultiple":  5.0
                                            },
                               "takeProfit":  {
                                                  "method":  "RrMultiple",
                                                  "rrMultiple":  2.0
                                              },
                               "breakeven":  {
                                                 "enabled":  true,
                                                 "triggerRMultiple":  1.0,
                                                 "offsetPips":  1.0,
                                                 "offsetSpreadMultiple":  1.0
                                             },
                               "trailing":  {
                                                "enabled":  true,
                                                "mode":  "Auto",
                                                "method":  "AtrMultiple",
                                                "atrMultiple":  2.0
                                            }
                           },
    "parameters":  {
                       "atrPeriod":  14,
                       "rangeStartUtc":  "07:00:00",
                       "rangeEndUtc":  "08:00:00",
                       "entryWindowStartUtc":  "08:00:00",
                       "entryWindowEndUtc":  "11:00:00",
                       "flattenTimeUtc":  "16:00:00"
                   },
    "reentry":  {
                    "blockWhileSameDirectionOpen":  true,
                    "cooldownBarsAfterSl":  5,
                    "cooldownBarsAfterTp":  2,
                    "cooldownBarsAfterEntry":  3
                }
}
