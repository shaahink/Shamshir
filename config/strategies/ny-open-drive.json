{
    "id":  "ny-open-drive",
    "displayName":  "NY Open Drive",
    "enabled":  true,
    "riskProfileId":  "standard",
    "thesis":  "The direction of the first bar after the 13:30 UTC New York open continues through the session; enter with that opening drive once per day and flatten at 20:00.",
    "expectedTradesPerWeek":  5,
    "expectedHoldBars":  20,
    "regimeFilter":  {
                         "allowTrending":  true,
                         "allowRanging":  true,
                         "allowHighVolatility":  true,
                         "allowLowVolatility":  true,
                         "allowUnknown":  true
                     },
    "orderEntry":  {
                        "method":  "LimitOffset",
                        "limitOffsetPips":  3.0,
                        "limitOffsetAtrFraction":  0.15,
                        "limitOrderExpiryBars":  12,
                        "maxSlippagePips":  2.0,
                        "maxSlippageSpreadMultiple":  2.0
                    },
    "positionManagement":  {
                               "stopLoss":  {
                                                "method":  "AtrMultiple",
                                                "atrMultiple":  1.5,
                                                "maxSlAtrMultiple":  5.0
                                            },
                               "takeProfit":  {
                                                  "method":  "RrMultiple",
                                                  "rrMultiple":  2.0
                                              },
                               "breakeven":  {
                                                 "enabled":  true,
                                                 "triggerRMultiple":  1.0,
                                                 "offsetPips":  1.0,
                                                 "offsetSpreadMultiple":  1.0
                                             },
                               "trailing":  {
                                                "enabled":  true,
                                                "mode":  "Auto",
                                                "method":  "AtrMultiple",
                                                "atrMultiple":  2.0
                                            }
                           },
    "parameters":  {
                       "atrPeriod":  14,
                       "signalStartUtc":  "13:30:00",
                       "signalEndUtc":  "15:00:00",
                       "flattenTimeUtc":  "20:00:00",
                       "mode":  "drive"
                   },
    "reentry":  {
                    "blockWhileSameDirectionOpen":  true,
                    "cooldownBarsAfterSl":  5,
                    "cooldownBarsAfterTp":  2,
                    "cooldownBarsAfterEntry":  3
                }
}
