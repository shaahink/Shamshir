{
    "id":  "ema-alignment",
    "displayName":  "EMA Alignment v1",
    "enabled":  true,
    "riskProfileId":  "standard",
    "thesis":  "After a fast/slow EMA crossover, the FIRST pullback touch of the fast EMA is a low-risk continuation entry in the new trend's direction.",
    "expectedTradesPerWeek":  1,
    "expectedHoldBars":  15,
    "regimeFilter":  {
                         "allowTrending":  true,
                         "allowRanging":  true,
                         "allowHighVolatility":  true,
                         "allowLowVolatility":  true,
                         "allowUnknown":  true
                     },
    "orderEntry":  {
                       "method":  "Market",
                       "maxSlippagePips":  2.0,
                       "maxSlippageSpreadMultiple":  2.0
                   },
    "positionManagement":  {
                               "stopLoss":  {
                                                "method":  "AtrMultiple",
                                                "atrMultiple":  1.5,
                                                "maxSlAtrMultiple":  5.0
                                            },
                               "takeProfit":  {
                                                  "method":  "RrMultiple",
                                                  "rrMultiple":  2.0
                                              },
                               "breakeven":  {
                                                 "enabled":  true,
                                                 "triggerRMultiple":  1.0,
                                                 "offsetPips":  1.0,
                                                 "offsetSpreadMultiple":  1.0
                                             },
                               "trailing":  {
                                                "enabled":  true,
                                                "mode":  "Auto",
                                                "method":  "AtrMultiple",
                                                "atrMultiple":  2.5
                                            }
                           },
    "parameters":  {
                       "fastPeriod":  20,
                       "slowPeriod":  50,
                       "atrPeriod":  14
                   },
    "reentry":  {
                    "blockWhileSameDirectionOpen":  true,
                    "cooldownBarsAfterSl":  5,
                    "cooldownBarsAfterTp":  2,
                    "cooldownBarsAfterEntry":  3
                }
}