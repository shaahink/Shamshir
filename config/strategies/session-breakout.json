{
  "id": "session-breakout",
  "displayName": "Session Breakout v1",
  "enabled": true,
  "symbols": ["EURUSD", "GBPUSD"],
  "riskProfileId": "standard",
  "timeframe": "H1",
  "regimeFilter": {
    "allowTrending": true,
    "allowRanging": true,
    "allowHighVolatility": true,
    "allowLowVolatility": true,
