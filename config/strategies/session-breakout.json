{
    "id":  "session-breakout",
    "displayName":  "Session Breakout v1",
    "enabled":  true,
    "riskProfileId":  "standard",
    "thesis":  "Price breaking out of the quiet Asian/early-European range during the London/NY window continues in that direction before the session's daily flatten.",
    "expectedTradesPerWeek":  2,
    "expectedHoldBars":  6,
    "regimeFilter":  {
                         "allowTrending":  true,
                         "allowRanging":  true,
                         "allowHighVolatility":  true,
                         "allowLowVolatility":  true,
                         "allowUnknown":  true
                     },
    "orderEntry":  {
                        "method":  "LimitOffset",
                        "limitOffsetPips":  3.0,
                        "limitOffsetAtrFraction":  0.15,
                        "limitOrderExpiryBars":  12,
                        "maxSlippagePips":  2.0,
                        "maxSlippageSpreadMultiple":  2.0
                    },
    "positionManagement":  {
                               "stopLoss":  {
                                                "method":  "AtrMultiple",
                                                "atrMultiple":  1.5,
                                                "maxSlAtrMultiple":  5.0
                                            },
                               "takeProfit":  {
                                                  "method":  "RrMultiple",
                                                  "rrMultiple":  2.0
                                              },
                               "breakeven":  {
                                                 "enabled":  true,
                                                 "triggerRMultiple":  1.0,
                                                 "offsetPips":  1.0,
                                                 "offsetSpreadMultiple":  1.0
                                             },
                               "trailing":  {
                                                "enabled":  true,
                                                "mode":  "Auto",
                                                "method":  "AtrMultiple",
                                                "atrMultiple":  2.0
                                            }
                           },
    "parameters":  {
                       "atrPeriod":  14,
                       "rangeStartUtc":  "05:00:00",
                       "rangeEndUtc":  "07:00:00",
                       "entryWindowEndUtc":  "09:00:00",
                       "flattenTimeUtc":  "12:00:00"
                   },
    "reentry":  {
                    "blockWhileSameDirectionOpen":  true,
                    "cooldownBarsAfterSl":  5,
                    "cooldownBarsAfterTp":  2,
                    "cooldownBarsAfterEntry":  3
                }
}