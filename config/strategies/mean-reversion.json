{
  "id": "mean-reversion",
  "displayName": "Mean Reversion v1",
  "enabled": true,
  "symbols": ["EURUSD", "GBPUSD"],
  "riskProfileId": "standard",
  "timeframe": "H1",
  "regimeFilter": {
    "allowTrending": false,
    "allowRanging": true,
    "allowHighVolatility": true,
    "allowLowVolatility": true,
    "allowUnknown": true
  },
  "orderEntry": {
    "method": "Market",
    "maxSlippagePips": 2.0
  },
  "positionManagement": {
    "stopLoss": { "method": "AtrMultiple", "atrMultiple": 1.5 },
    "takeProfit": { "method": "RrMultiple", "rrMultiple": 1.0 }
  },
  "parameters": {
    "rsiPeriod": 14,
    "bbPeriod": 20,
    "bbStdDev": 2.0,
    "atrPeriod": 14
  }
}
