                                              },
                               "breakeven":  {
                                                 "enabled":  true,
                                                 "triggerRMultiple":  1.0,
                                                 "offsetPips":  1.0
                                             },
                               "trailing":  {
                                                "enabled":  true,
                                                "mode":  "Auto",
                                                "method":  "AtrMultiple",
                                                "atrMultiple":  2.5
                                            }
                           },
    "parameters":  {
                       "lookbackBars":  20,
                       "maPeriod":  50,
                       "atrPeriod":  14
                   },
    "reentry":  {
                    "blockWhileSameDirectionOpen":  true,
                    "cooldownBarsAfterSl":  5,
                    "cooldownBarsAfterTp":  2,
                    "cooldownBarsAfterEntry":  3
                }
}