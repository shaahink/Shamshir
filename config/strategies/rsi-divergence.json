{
    "id":  "rsi-divergence",
    "displayName":  "RSI Divergence",
    "enabled":  true,
    "riskProfileId":  "standard",
    "thesis":  "Price making a fresh extreme while RSI fails to confirm (divergence) signals exhaustion; a confirmed break of the divergence pivot marks the reversal entry.",
    "expectedTradesPerWeek":  1,
    "expectedHoldBars":  20,
    "regimeFilter":  {
                         "allowTrending":  false,
                         "allowHighVolatility":  false
                     },
    "orderEntry":  {
                        "method":  "LimitOffset",
                        "limitOffsetPips":  3.0,
                        "limitOffsetAtrFraction":  0.15,
                        "limitOrderExpiryBars":  12,
                        "maxSlippagePips":  2.0,
                        "maxSlippageSpreadMultiple":  2.0
                    },
    "positionManagement":  {
                               "stopLoss":  {
                                                "method":  "AtrMultiple",
                                                "atrMultiple":  1.5,
                                                "maxSlAtrMultiple":  5.0
                                            },
                               "takeProfit":  {
                                                  "method":  "RrMultiple",
                                                  "rrMultiple":  2.0
                                              }
                           },
    "parameters":  {
                       "rsiPeriod":  14,
                       "divergenceLookback":  50,
                       "atrPeriod":  14,
                       "slAtrMultiple":  1.5,
                       "tpRrMultiple":  2.0
                   },
    "reentry":  {
                    "blockWhileSameDirectionOpen":  true,
                    "cooldownBarsAfterSl":  5,
                    "cooldownBarsAfterTp":  2,
                    "cooldownBarsAfterEntry":  3
                }
}