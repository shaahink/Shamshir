@page "/runs/{RunId}"

@inject IBacktestQueryService Query
@inject HttpClient Http

<h3>Run Detail: @RunId</h3>

@if (_run is null)
{
    <p>Loading...</p>
}
else
{
    <div class="row mb-3">
        <div class="col-3"><strong>Symbol:</strong> @_run.Symbol</div>
        <div class="col-3"><strong>Period:</strong> @_run.Period</div>
        <div class="col-3"><strong>Range:</strong> @_run.BacktestFrom.ToString("yyyy-MM-dd") → @_run.BacktestTo.ToString("yyyy-MM-dd")</div>
        <div class="col-3"><strong>Balance:</strong> $@_run.InitialBalance.ToString("N0")</div>
    </div>

    <div class="row mb-3">
        <div class="col-md-8">
            <div class="card"><div class="card-header">Equity Curve</div><div class="card-body">
                <EquityCurveChart ElementId="run-equity" />
            </div></div>
        </div>
        <div class="col-md-4">
            <div class="card mb-2"><div class="card-header">Summary</div><div class="card-body">
                <table class="table table-sm"><tbody>
                    <tr><td>Net P&L</td><td class="text-@(_run.NetProfit >= 0 ? "success" : "danger")">@($"{_run.NetProfit:N2}")</td></tr>
                    <tr><td>Trades</td><td>@_run.TotalTrades</td></tr>
                    <tr><td>Wins</td><td>@_run.WinningTrades</td></tr>
                    <tr><td>Win Rate</td><td>@($"{_run.WinRatePct:F1}%")</td></tr>
                    <tr><td>Max DD</td><td>@($"{_run.MaxDrawdownPct:F2}%")</td></tr>
                </tbody></table>
            </div></div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card mb-3"><div class="card-header">Signal Audit (Per Strategy)</div><div class="card-body">
                <table class="table table-sm table-striped">
                    <thead><tr><th>Strategy</th><th>Bars Eval</th><th>Signals</th><th>Trades</th><th>Wins</th><th>Losses</th><th>Win%</th><th>Top Rejections</th></tr></thead>
                    <tbody>
                        @if (_breakdowns is not null)
                        {
                            @foreach (var b in _breakdowns)
                            { <tr><td>@b.StrategyId</td><td>@b.TotalBarsEvaluated</td><td>@b.SignalsFired</td><td>@b.TradesOpened</td><td>@b.Wins</td><td>@b.Losses</td><td>@b.WinRatePct.ToString("F1")%</td><td>@string.Join(", ", b.TopRejections)</td></tr> }
                        }
                    </tbody>
                </table>
            </div></div>
        </div>
    </div>
}

@code {
    [Parameter] public string RunId { get; set; } = "";

    private BacktestRunView? _run;
    private IReadOnlyList<StrategyPerformance>? _breakdowns;

    protected override async Task OnInitializedAsync()
    {
        _run = await Query.GetRunAsync(RunId, CancellationToken.None);
        _breakdowns = await Query.GetStrategyBreakdownAsync(RunId, CancellationToken.None);
    }
}
