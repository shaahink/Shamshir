@page "/experiments"

@inject HttpClient Http

<h3>Experiments</h3>

@if (_experiments is null)
{
    <p>Loading...</p>
}
else if (_experiments.Length == 0)
{
    <p class="text-muted">No experiments found. Post a spec to <code>POST /api/experiments</code> to run one.</p>
}
else
{
    <table class="table table-sm table-striped">
        <thead><tr><th>Name</th><th>Status</th><th>Created</th><th>Runs</th></tr></thead>
        <tbody>
            @foreach (var e in _experiments)
            { <tr><td>@e.name</td><td><span class="badge @StatusBadge(e.status)">@e.status</span></td><td>@e.createdUtc.ToString("yyyy-MM-dd")</td><td>@e.runCount</td></tr> }
        </tbody>
    </table>
}

<div class="card mt-3">
    <div class="card-header">Run Experiment</div>
    <div class="card-body">
        <p>Paste an experiment spec JSON and click Run:</p>
        <textarea class="form-control mb-2" rows="12" @bind="_specText"></textarea>
        <button class="btn btn-primary" @onclick="RunExperiment" disabled="@_running">@(_running ? "Running..." : "Run Experiment")</button>
        @if (!string.IsNullOrEmpty(_resultMsg))
        { <div class="mt-2 alert @(_resultOk ? "alert-success" : "alert-danger")">@_resultMsg</div> }
    </div>
</div>

@code {
    private Experiment[]? _experiments;
    private string _specText = GetSampleSpec();
    private bool _running;
    private string _resultMsg = "";
    private bool _resultOk;

    private record Experiment(Guid id, string name, string status, DateTime createdUtc, int runCount);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var json = await Http.GetStringAsync("/api/experiments");
            _experiments = JsonSerializer.Deserialize<Experiment[]>(json);
        }
        catch { }
    }

    private async Task RunExperiment()
    {
        _running = true; _resultMsg = "";
        try
        {
            var content = new StringContent(_specText, System.Text.Encoding.UTF8, "application/json");
            var resp = await Http.PostAsync("/api/experiments", content);
            var body = await resp.Content.ReadAsStringAsync();
            _resultOk = resp.IsSuccessStatusCode;
            _resultMsg = body;
        }
        catch (Exception ex) { _resultMsg = ex.Message; _resultOk = false; }
        _running = false;
    }

    private static string StatusBadge(string s) => s switch
    {
        "Completed" => "bg-success",
        "Running" => "bg-primary",
        "Failed" => "bg-danger",
        _ => "bg-secondary"
    };

    private static string GetSampleSpec() => """
    {
      "name": "trailing-test",
      "hypothesis": "Structure trail improves R vs StepPips",
      "symbols": ["EURUSD"],
      "timeframes": ["H1"],
      "strategies": ["trend-breakout"],
      "from": "2023-06-01",
      "to": "2023-08-01",
      "walkForward": { "folds": 2, "trainFraction": 0.7 },
      "variants": [
        { "label": "baseline" },
        { "label": "structure", "overrides": { "positionManagement.trailing.method": "Structure" } }
      ],
      "maxRuns": 8
    }
    """;
}
