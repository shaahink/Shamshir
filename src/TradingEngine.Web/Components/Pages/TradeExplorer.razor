@page "/explorer"
@inject IBacktestQueryService Query
@inject HttpClient Http

<h3>Trade Explorer</h3>

<div class="row">
    <div class="col-12">
        <button class="btn btn-outline-primary btn-sm mb-2" @onclick="LoadRuns">Refresh</button>
        <table class="table table-sm table-hover">
            <thead><tr><th>Run</th><th>Symbol</th><th>Period</th><th>Started</th><th>Net</th><th>DD%</th><th>Trades</th><th>Win%</th></tr></thead>
            <tbody>
                @foreach (var r in Runs)
                {
                    <tr>
                        <td>@r.RunId[..Math.Min(8, r.RunId.Length)]</td>
                        <td>@r.Symbol</td><td>@r.Period</td>
                        <td>@r.StartedAt.ToString("yyyy-MM-dd")</td>
                        <td>@r.NetProfit.ToString("F2")</td><td>@r.MaxDrawdownPct.ToString("F1")%</td>
                        <td>@r.TotalTrades</td><td>@r.WinRatePct.ToString("F1")%</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<RunView> Runs = new();

    private class RunView
    {
        public string RunId { get; set; } = ""; public string Symbol { get; set; } = "";
        public string Period { get; set; } = ""; public DateTime StartedAt { get; set; }
        public decimal NetProfit { get; set; } public double MaxDrawdownPct { get; set; }
        public int TotalTrades { get; set; } public double WinRatePct { get; set; }
    }

    protected override async Task OnInitializedAsync() => await LoadRuns();

    private async Task LoadRuns()
    {
        try
        {
            var all = await Query.GetAllRunsAsync(CancellationToken.None);
            Runs = all.Select(r => new RunView { RunId = r.RunId, Symbol = r.Symbol, Period = r.Period, StartedAt = r.StartedAt, NetProfit = r.NetProfit, MaxDrawdownPct = (double)r.MaxDrawdownPct, TotalTrades = r.TotalTrades, WinRatePct = r.WinRatePct }).ToList();
        }
        catch { }
    }
}
