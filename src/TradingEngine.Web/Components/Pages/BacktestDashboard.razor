@page "/dashboard"
@inject HttpClient Http
@inject BacktestProgressStore ProgressStore
@inject IBacktestQueryService Query
@implements IDisposable

<h3>Backtest Dashboard</h3>

<div class="row mb-3">
    <div class="col-md-8">
        <div class="card"><div class="card-header">New Backtest</div><div class="card-body">
            <div class="row">
                <div class="col-3"><label>Symbol</label>
                    <select class="form-select" @bind="_selSymbol">
                        <option value="EURUSD">EURUSD</option><option value="GBPUSD">GBPUSD</option>
                        <option value="USDJPY">USDJPY</option><option value="AUDUSD">AUDUSD</option>
                    </select></div>
                <div class="col-2"><label>From</label>
                    <input class="form-control" type="date" @bind-value="_fromDate" @bind-value:format="yyyy-MM-dd" /></div>
                <div class="col-2"><label>To</label>
                    <input class="form-control" type="date" @bind-value="_toDate" @bind-value:format="yyyy-MM-dd" /></div>
                <div class="col-2"><label>TF</label>
                    <select class="form-select" @bind="_timeframe">
                        <option value="h1">H1</option><option value="h4">H4</option><option value="d1">D1</option>
                    </select></div>
                <div class="col-3 d-flex align-items-end">
                    <button class="btn btn-primary" @onclick="StartBacktest" disabled="@_isRunning">
                        @(_isRunning ? "Running..." : "Run Backtest")
                    </button></div>
            </div></div></div></div>
    <div class="col-md-4">
        <GovernorBanner State="@_governorState" Reason="@_governorReason" />
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card mb-3"><div class="card-header">Equity Curve</div><div class="card-body">
            <EquityCurveChart @ref="_equityChart" ElementId="live-equity" />
        </div></div>
    </div>
    <div class="col-md-6">
        <div class="card mb-3"><div class="card-header">Trade Feed</div><div class="card-body" style="max-height:300px;overflow-y:auto">
            <table class="table table-sm table-striped">
                <thead><tr><th>Time</th><th>Strat</th><th>Dir</th><th>Lots</th><th>Entry</th><th>Exit</th><th>PnL</th><th>R</th></tr></thead>
                <tbody>
                    @foreach (var t in _trades)
                    { <tr class="@(t.PnL >= 0 ? "table-success" : "table-danger")"><td>@t.ClosedAt.ToString("MM-dd HH:mm")</td><td>@t.Strategy[..Math.Min(4,t.Strategy.Length)]</td><td>@t.Dir</td><td>@($"{t.Lots:F2}")</td><td>@($"{t.Entry:F5}")</td><td>@($"{t.Exit:F5}")</td><td>@($"{t.PnL:F2}")</td><td>@($"{t.R:F2}")</td></tr> }
                </tbody>
            </table>
        </div></div>
    </div>
</div>

<div class="row">
    <div class="col-md-3">
        <div class="card"><div class="card-header">Bar Progress</div><div class="card-body">
            <p><strong>@_barCount</strong> bars processed @if (_barCount > 0 && _startTime != default) { <small>(@Speed bars/s)</small> } </p>
            <p>Sim Time: @_simTime</p>
        </div></div>
    </div>
    <div class="col-md-9">
        <div class="card"><div class="card-header">Log <span class="badge bg-secondary">@_logLevel</span></div><div class="card-body" style="max-height:250px;overflow-y:auto;font-family:monospace;font-size:0.85em">
            @foreach (var l in _logs.TakeLast(50))
            { <div class="text-@(l.Contains("[ERR") ? "danger" : l.Contains("WARN") ? "warning" : "muted")">@l</div> }
        </div></div>
    </div>
</div>

@code {
    private string _selSymbol = "EURUSD";
    private DateTime _fromDate = DateTime.UtcNow.AddMonths(-1);
    private DateTime _toDate = DateTime.UtcNow;
    private string _timeframe = "h1";
    private bool _isRunning;
    private string _runId = "";
    private string _governorState = "Normal";
    private string _governorReason = "";
    private string _logLevel = "Info";
    private string _simTime = "";
    private int _barCount;
    private DateTime _startTime;
    private decimal Speed => _barCount / Math.Max(1, (decimal)(DateTime.UtcNow - _startTime).TotalSeconds);
    private string _lastStatus = "";

    private EquityCurveChart? _equityChart;
    private readonly List<TradeRow> _trades = new();
    private readonly List<string> _logs = new();
    private CancellationTokenSource? _pollCts;

    private record TradeRow(DateTime ClosedAt, string Strategy, string Dir, decimal Lots, decimal Entry, decimal Exit, decimal PnL, double R);

    private async Task StartBacktest()
    {
        _isRunning = true; _trades.Clear(); _logs.Clear(); _barCount = 0; _startTime = DateTime.UtcNow; _simTime = ""; _governorState = "Normal"; _lastStatus = "";
        try
        {
            var payload = new { symbol = _selSymbol, period = _timeframe, start = _fromDate.ToString("yyyy-MM-dd"), end = _toDate.ToString("yyyy-MM-dd"), balance = 100000 };
            var content = new StringContent(JsonSerializer.Serialize(payload), System.Text.Encoding.UTF8, "application/json");
            var response = await Http.PostAsync("/api/backtest/start", content);
            var body = await response.Content.ReadAsStringAsync();
            var result = JsonSerializer.Deserialize<RunResponse>(body);
            if (result is not null) _runId = result.runId;
            _logs.Add($"{DateTime.UtcNow:HH:mm:ss} Run started: {_runId}");
            StartPolling();
        }
        catch (Exception ex) { _logs.Add($"[ERR] Start failed: {ex.Message}"); _isRunning = false; }
    }

    private void StartPolling()
    {
        _pollCts?.Cancel();
        _pollCts = new CancellationTokenSource();
        _ = PollAsync(_pollCts.Token);
    }

    private async Task PollAsync(CancellationToken ct)
    {
        while (!ct.IsCancellationRequested && !string.IsNullOrEmpty(_runId))
        {
            try
            {
                var resp = await Http.GetStringAsync($"/api/backtest/{_runId}/status", ct);
                var status = JsonSerializer.Deserialize<StatusResponse>(resp);
                if (status is not null)
                {
                    _lastStatus = status.status ?? "";
                    _barCount = status.barCount;
                    _simTime = status.simTime ?? "";
                    if (status.trades is { Length: > 0 })
                    {
                        foreach (var t in status.trades)
                            _trades.Add(new TradeRow(t.closedAt, t.strategy, t.direction, t.lots, t.entry, t.exit, t.pnl, t.r));
                    }
                    if (status.logs is { Length: > 0 })
                        foreach (var l in status.logs) _logs.Add(l);
                    if (status.governor is not null)
                    { _governorState = status.governor.state; _governorReason = status.governor.reason; }
                    if (_lastStatus is "completed" or "failed") break;
                }
            }
            catch { }
            await Task.Delay(1000, ct);
            StateHasChanged();
        }
        _isRunning = false;
    }

    private record RunResponse { public string runId { get; set; } = ""; public string status { get; set; } = ""; }
    private record StatusResponse { public string? status { get; set; } public string? simTime { get; set; } public int barCount { get; set; } public TradeStatus[]? trades { get; set; } public string[]? logs { get; set; } public GovernorStatus? governor { get; set; } }
    private record TradeStatus(DateTime closedAt, string strategy, string direction, decimal lots, decimal entry, decimal exit, decimal pnl, double r);
    private record GovernorStatus(string state, string reason);

    public void Dispose() { _pollCts?.Cancel(); _pollCts?.Dispose(); }
}
