@page "/dashboard"
@inject HttpClient Http

<h3>Backtest Dashboard</h3>

<div class="row mb-3">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">New Backtest</div>
            <div class="card-body">
                <div class="row">
                    <div class="col-4">
                        <label>Symbol</label>
                        <select class="form-select" @bind="SelSymbol">
                            <option value="EURUSD">EURUSD</option><option value="GBPUSD">GBPUSD</option>
                            <option value="USDJPY">USDJPY</option><option value="AUDUSD">AUDUSD</option>
                        </select>
                    </div>
                    <div class="col-4">
                        <label>From</label>
                        <input class="form-control" type="date" @bind-value="_fromDate" @bind-value:format="yyyy-MM-dd" />
                        <label>To</label>
                        <input class="form-control" type="date" @bind-value="_toDate" @bind-value:format="yyyy-MM-dd" />
                        <label>Timeframe</label>
                        <select class="form-select" @bind="Timeframe">
                            <option value="h1">H1</option><option value="h4">H4</option><option value="d1">D1</option>
                        </select>
                    </div>
                    <div class="col-4 d-flex align-items-end">
                        <button class="btn btn-primary" @onclick="StartBacktest" disabled="@IsRunning">
                            @(IsRunning ? "Running..." : "Run Backtest")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">Latest Run</div>
            <div class="card-body">
                @if (RunResult is not null)
                {
                    <p>Run: @RunResult.runId</p>
                    <p>Status: @RunResult.status</p>
                }
                else { <p class="text-muted">Run a backtest to see results.</p> }
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <EquityCurveChart @ref="EquityChart" ElementId="live-equity" />
    </div>
</div>

@code {
    private string SelSymbol = "EURUSD";
    private DateTime _fromDate = DateTime.UtcNow.AddMonths(-1);
    private DateTime _toDate = DateTime.UtcNow;
    private int Balance = 100000;
    private string Timeframe = "h1";
    private bool IsRunning;
    private RunResponse? RunResult;
    private EquityCurveChart? EquityChart;

    private class RunResponse { public string runId { get; set; } = ""; public string status { get; set; } = ""; }

    private async Task StartBacktest()
    {
        IsRunning = true;
        try
        {
            var payload = new { symbol = SelSymbol, period = Timeframe, start = _fromDate.ToString("yyyy-MM-dd"), end = _toDate.ToString("yyyy-MM-dd"), balance = Balance };
            var content = new StringContent(JsonSerializer.Serialize(payload), System.Text.Encoding.UTF8, "application/json");
            var response = await Http.PostAsync("/api/backtest/start", content);
            var body = await response.Content.ReadAsStringAsync();
            RunResult = JsonSerializer.Deserialize<RunResponse>(body);
        }
        catch { }
        IsRunning = false;
    }
}
