@page "/compare"
@inject HttpClient Http

<h3>Backtest Comparison</h3>
<div class="row mb-2">
    <div class="col-12">
        <label>Run IDs (comma-separated):</label>
        <input class="form-control" @bind="RunIdsInput" placeholder="abc123,def456" />
        <button class="btn btn-primary btn-sm mt-1" @onclick="Compare">Compare</button>
    </div>
</div>
@if (Results.Any())
{
    <table class="table table-sm">
        <thead><tr><th>Run</th><th>Net PnL</th><th>Max DD</th><th>Win Rate</th><th>Trades</th></tr></thead>
        <tbody>
            @foreach (var r in Results)
            {
                <tr><td>@(r.RunId.Length > 8 ? r.RunId[..8] : r.RunId)</td><td>@r.NetProfit.ToString("F2")</td><td>@r.MaxDrawdownPct.ToString("F1")%</td><td>@r.WinRatePct.ToString("F1")%</td><td>@r.TotalTrades</td></tr>
            }
        </tbody>
    </table>
}
@if (PassProb is not null)
{
    <PassProbabilityGauge Probability="@PassProb.ProbabilityOfPass" DailyBreach="@PassProb.ProbabilityOfDailyBreach" MaxBreach="@PassProb.ProbabilityOfMaxBreach" ProjectedEquity="@PassProb.ProjectedFinalEquity" Recommendation="@PassProb.Recommendation" />
}

@code {
    private string RunIdsInput = "";
    private List<CompareRow> Results = new();
    private PassProbabilityEstimate? PassProb;

    private class CompareRow { public string RunId { get; set; } = ""; public decimal NetProfit { get; set; } public double MaxDrawdownPct { get; set; } public double WinRatePct { get; set; } public int TotalTrades { get; set; } }

    private async Task Compare()
    {
        try
        {
            Results = await Http.GetFromJsonAsync<List<CompareRow>>($"/api/backtest/compare?runIds={RunIdsInput}") ?? new();
            var ids = RunIdsInput.Split(',', StringSplitOptions.RemoveEmptyEntries);
            if (ids.Length > 0)
                PassProb = await Http.GetFromJsonAsync<PassProbabilityEstimate>($"/api/backtest/{ids[0]}/pass-probability");
        }
        catch { }
    }
}
