@* StrategyStatusCard - per-strategy card with toggle and stats *@
<div class="card mb-2">
    <div class="card-body">
        <h5 class="card-title">@DisplayName <span class="badge bg-secondary">@Id</span></h5>
        <span class="badge @(IsEnabled ? "bg-success" : "bg-danger")">@(IsEnabled ? "Active" : "Disabled")</span>
        <button class="btn btn-sm @(IsEnabled ? "btn-outline-danger" : "btn-outline-success")" @onclick="Toggle">@(IsEnabled ? "Disable" : "Enable")</button>
        <div class="mt-2">
            <small>Trades: @TotalTrades | Win Rate: @WinRate.ToString("F1")% | PnL: @PnL.ToString("F2") | PF: @ProfitFactor.ToString("F2")</small>
        </div>
    </div>
</div>

@code {
    [Parameter] public string Id { get; set; } = "";
    [Parameter] public string DisplayName { get; set; } = "";
    [Parameter] public bool IsEnabled { get; set; } = true;
    [Parameter] public int TotalTrades { get; set; }
    [Parameter] public double WinRate { get; set; }
    [Parameter] public decimal PnL { get; set; }
    [Parameter] public decimal ProfitFactor { get; set; }
    [Parameter] public EventCallback<string> OnToggle { get; set; }

    private async Task Toggle() => await OnToggle.InvokeAsync(Id);
}
