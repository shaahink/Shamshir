@* OhlcTradeChart - lightweight-charts candlestick with trade markers *@
<div id="@ElementId" style="width:100%;height:400px"></div>

@code {
    [Parameter] public string ElementId { get; set; } = "ohlc-chart";
    [Inject] private IJSRuntime JS { get; set; } = default!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("createOhlcChart", ElementId);
    }

    public async Task SetBars(List<BarDataPoint> bars)
    {
        var jsData = bars.Select(b => new { time = new DateTimeOffset(b.Time).ToUnixTimeSeconds(), open = (double)b.Open, high = (double)b.High, low = (double)b.Low, close = (double)b.Close }).ToList();
        await JS.InvokeVoidAsync("setOhlcData", ElementId, jsData);
    }

    public async Task AddMarkers(MarkerData? entry, MarkerData? exit, decimal? sl, decimal? tp)
    {
        var entryJs = entry is null ? null : new { time = new DateTimeOffset(entry.Time).ToUnixTimeSeconds(), dir = entry.Direction };
        var exitJs = exit is null ? null : new { time = new DateTimeOffset(exit.Time).ToUnixTimeSeconds(), dir = exit.Direction };
        await JS.InvokeVoidAsync("addTradeMarkers", ElementId, entryJs, exitJs, sl.HasValue ? new { price = (double)sl.Value } : null, tp.HasValue ? new { price = (double)tp.Value } : null);
    }
}
