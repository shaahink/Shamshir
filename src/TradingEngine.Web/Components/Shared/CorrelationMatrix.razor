@* CorrelationMatrix - colored table of Pearson r values *@
<div>
    <h5>Correlation Matrix</h5>
    <table class="table table-sm">
        <thead>
            <tr>
                <th></th>
                @foreach (var sym in Symbols)
                { <th>@sym</th> }
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Symbols.Count; i++)
            {
                <tr>
                    <td><strong>@Symbols[i]</strong></td>
                    @for (int j = 0; j < Symbols.Count; j++)
                    {
                        var val = i < Matrix.Count && j < Matrix[i].Count ? Matrix[i][j] : 0;
                        <td style="background:@ColorFor(val)">@val.ToString("F2")</td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter] public List<string> Symbols { get; set; } = new();
    [Parameter] public List<List<double>> Matrix { get; set; } = new();

    private static string ColorFor(double r)
    {
        if (r > 0) return $"rgba(38,166,154,{Math.Abs(r):F2})";
        if (r < 0) return $"rgba(239,83,80,{Math.Abs(r):F2})";
        return "transparent";
    }
}
