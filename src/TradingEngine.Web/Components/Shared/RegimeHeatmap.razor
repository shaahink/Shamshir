@* RegimeHeatmap - calendar grid with color cells *@
<div>
    <h5>Regime Heatmap</h5>
    <div style="display:flex; flex-wrap:wrap; gap:4px">
        @foreach (var cell in Cells)
        {
            <div style="width:20px;height:20px;background:@GetColor(cell.Regime)" title="@cell.Date: @cell.Regime"></div>
        }
    </div>
    <div class="mt-1">
        <span style="color:#2196f3">Trending</span> |
        <span style="color:#ff9800">Ranging</span> |
        <span style="color:#ef5350">HighVol</span> |
        <span style="color:#4caf50">LowVol</span> |
        <span style="color:#9e9e9e">Unknown</span>
    </div>
</div>

@code {
    [Parameter] public List<RegimeCell> Cells { get; set; } = new();

    private static string GetColor(string regime) => regime switch
    {
        "Trending" => "#2196f3",
        "Ranging" => "#ff9800",
        "HighVolatility" => "#ef5350",
        "LowVolatility" => "#4caf50",
        _ => "#9e9e9e"
    };
}

public record RegimeCell(DateTime Date, string Regime);
