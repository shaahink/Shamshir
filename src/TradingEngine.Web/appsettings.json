{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": "Warning",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/web-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{Level:u3}] {Message:lj} {Exception}{NewLine}"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "CTrader": {
    "Comment": "Set these via dotnet user-secrets or environment variables. Without them, backtests will fail.",
    "CtId": "",
    "PwdFile": "",
    "Account": ""
  }
}
