@page "/strategies"
@model StrategiesModel
@{
    ViewData["Title"] = "Strategies";
}
<h1>Strategy Bank</h1>

<div class="grid" style="margin-bottom:var(--sp-4)">
    <div class="card"><h2>Loaded Strategies</h2><div class="value" id="stratCount">--</div></div>
</div>

<div class="card">
    <table>
        <thead><tr><th>Name</th><th>ID</th><th>Symbols</th><th>Timeframe</th><th>Enabled</th></tr></thead>
        <tbody id="stratTable">
            <tr><td colspan="5"><div class="skeleton" style="height:20px"></div></td></tr>
        </tbody>
    </table>
</div>

@section Scripts {
    <script type="module">
        async function load() {
            try {
                const r = await fetch('/api/strategies');
                const data = await r.json();
                document.getElementById('stratCount').textContent = data.length || 0;
                const tbody = document.getElementById('stratTable');
                tbody.innerHTML = data.map(s => '<tr>' +
                    '<td>' + (s.displayName || s.id || '--') + '</td>' +
                    '<td style="font-family:var(--font-mono)">' + (s.id || '--') + '</td>' +
                    '<td>' + (s.symbols ? s.symbols.join(', ') : '--') + '</td>' +
                    '<td>' + (s.timeframe || '--') + '</td>' +
                    '<td><span class="pill ' + (s.enabled ? 'pill--normal' : 'pill--softstop') + '">' + (s.enabled ? 'Yes' : 'No') + '</span></td>' +
                    '</tr>').join('');
            } catch (e) {
                console.error('Failed to load strategies', e);
                document.getElementById('stratCount').textContent = 'Error';
            }
        }
        load();
    </script>
}
