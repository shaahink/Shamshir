@page
@model EventsModel
@{
    ViewData["Title"] = "Events";
}
<h1>Engine Events</h1>
<table>
    <thead>
        <tr>
            <th>Time</th>
            <th>Type</th>
            <th>Details</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var evt in Model.Events)
        {
            <tr>
                <td>@evt.OccurredAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</td>
                <td>@evt.GetType().Name</td>
                <td>@evt</td>
            </tr>
        }
    </tbody>
</table>
