@page "/compliance"
@model ComplianceModel
@{
    ViewData["Title"] = "Compliance";
}
<h1>Compliance Dashboard</h1>

<div class="grid">
    <div class="card"><h2>Daily DD Limit</h2><div class="value" id="dailyDd">--</div></div>
    <div class="card"><h2>Max DD Limit</h2><div class="value" id="maxDd">--</div></div>
    <div class="card"><h2>Governor State</h2><div class="value" id="govState">--</div></div>
    <div class="card"><h2>Protection Mode</h2><div class="value" id="protectionMode">--</div></div>
</div>

<div class="card">
    <h2>Protection History</h2>
    <div id="protectionLedger" class="empty">
        <span>Loading protection ledger...</span>
    </div>
</div>

@section Scripts {
    <script type="module">
        async function load() {
            try {
                const r = await fetch('/api/protection/days');
                if (!r.ok) throw new Error(r.statusText);
                const data = await r.json();

                const ledger = document.getElementById('protectionLedger');
                if (data && data.length > 0) {
                    ledger.className = '';
                    ledger.innerHTML = '<table><thead><tr><th>Date</th><th>Status</th><th>Daily DD</th><th>Reason</th></tr></thead><tbody>' +
                        data.map(d => '<tr><td>' + d.date + '</td><td><span class="pill ' + (d.breached ? 'pill--hardstop' : 'pill--normal') + '">' + (d.breached ? 'Breached' : 'OK') + '</span></td><td class="num">' + (d.dailyDrawdown || 0).toFixed(2) + '%</td><td>' + (d.reason || '') + '</td></tr>').join('') +
                        '</tbody></table>';
                } else {
                    ledger.innerHTML = '<span>No protection events recorded</span>';
                }
            } catch (e) {
                console.error('Failed to load compliance data', e);
            }
        }
        load();
    </script>
}
