@page "/runs/{runId}/monitor"
@model MonitorModel
@{
    ViewData["Title"] = "Run Monitor";
    ViewData["RunId"] = Model.RunId;
}
<h1>Run Monitor</h1>

<div class="sim-clock" id="simClock">--</div>

<div class="progress-bar" style="margin-bottom:var(--sp-4)">
    <div class="progress-bar-fill" id="progressFill" style="width:0%"></div>
</div>

<div class="grid" style="margin-bottom:var(--sp-3)">
    <div class="kpi"><span class="kpi-label">Progress</span><span class="kpi-value" id="kpiPercent">0%</span></div>
    <div class="kpi"><span class="kpi-label">Speed</span><span class="kpi-value num" id="kpiSpeed">0 bars/s</span></div>
    <div class="kpi"><span class="kpi-label">ETA</span><span class="kpi-value" id="kpiEta">--</span></div>
    <div class="kpi"><span class="kpi-label">Elapsed</span><span class="kpi-value" id="kpiElapsed">--</span></div>
</div>

<div class="grid">
    <div class="card"><h2>Equity</h2><div class="value" id="kpiEquity">--</div></div>
    <div class="card"><h2>Daily DD</h2><div class="value" id="kpiDailyDd">--</div></div>
    <div class="card"><h2>Max DD</h2><div class="value" id="kpiMaxDd">--</div></div>
    <div class="card"><h2>Open Positions</h2><div class="value" id="kpiOpen">--</div></div>
</div>

<div id="breachBanner" class="banner--crit" style="display:none"></div>

<div class="card">
    <h2>Equity Curve</h2>
    <div id="equitySparkline" style="height:200px"></div>
</div>

<div class="grid" style="margin-bottom:var(--sp-4)">
    <div class="kpi"><span class="kpi-label">Signals</span><span class="kpi-value" id="countSignals">0</span></div>
    <div class="kpi"><span class="kpi-label">Orders</span><span class="kpi-value" id="countOrders">0</span></div>
    <div class="kpi"><span class="kpi-label">Fills</span><span class="kpi-value" id="countFills">0</span></div>
    <div class="kpi"><span class="kpi-label">Closes</span><span class="kpi-value" id="countCloses">0</span></div>
    <div class="kpi"><span class="kpi-label">Rejections</span><span class="kpi-value negative" id="countRejections">0</span></div>
    <div class="kpi"><span class="kpi-label">Breaches</span><span class="kpi-value negative" id="countBreaches">0</span></div>
</div>

<div class="card">
    <h2>Journal Feed</h2>
    <div class="journal-filters" style="margin-bottom:var(--sp-2);display:flex;gap:var(--sp-2)">
        <button class="tab active filter-all" data-filter="all">All</button>
        <button class="tab filter-SIGNAL" data-filter="SIGNAL">Signals</button>
        <button class="tab filter-ORDER" data-filter="ORDER">Orders</button>
        <button class="tab filter-FILL" data-filter="FILL">Fills</button>
        <button class="tab filter-CLOSE" data-filter="CLOSE">Trades</button>
        <button class="tab filter-REJECT" data-filter="REJECT">Rejections</button>
        <button class="tab filter-BREACH" data-filter="BREACH">Breaches</button>
    </div>
    <div id="journalFeed" class="journal-feed" style="max-height:400px;overflow-y:auto" aria-live="polite"></div>
</div>

<div id="completedCta" style="display:none;text-align:center;padding:var(--sp-5)">
    <a href="/runs/@Model.RunId/report" class="kpi-value" style="color:var(--accent);text-decoration:none;font-size:var(--fs-xl)">View Report</a>
</div>

<div id="loading" class="empty">
    <span class="empty-icon">-</span><span>Connecting to run...</span>
</div>
<div id="errorState" class="empty" style="display:none">
    <span class="empty-icon">!</span><span id="errorMsg">Connection lost. Reconnecting...</span>
</div>

@section Scripts {
    <script type="module">
        import { equityChart } from '/js/charts/index.js';
        import { createRunClient } from '/js/run-client.js';

        const runId = '@Model.RunId';
        const equityPoints = [];
        let chartHandle = null;
        let journalPaused = false;
        let activeFilter = 'all';
        let lastBreachCount = 0;

        const breachBanner = document.getElementById('breachBanner');
        const journalFeed = document.getElementById('journalFeed');
        const completedCta = document.getElementById('completedCta');
        const loading = document.getElementById('loading');
        const errorState = document.getElementById('errorState');

        document.querySelectorAll('.journal-filters button').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.journal-filters button').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                activeFilter = btn.dataset.filter;
                applyJournalFilter();
            });
        });

        journalFeed.addEventListener('mouseenter', () => { journalPaused = true; });
        journalFeed.addEventListener('mouseleave', () => { journalPaused = false; });

        function applyJournalFilter() {
            document.querySelectorAll('.journal-line').forEach(line => {
                const evt = line.dataset.event;
                line.style.display = (activeFilter === 'all' || evt === activeFilter) ? '' : 'none';
            });
        }

        function formatDuration(ms) {
            const s = Math.floor(ms / 1000);
            const m = Math.floor(s / 60);
            const h = Math.floor(m / 60);
            if (h > 0) return h + 'h ' + (m % 60) + 'm';
            if (m > 0) return m + 'm ' + (s % 60) + 's';
            return s + 's';
        }

        function initChart() {
            const container = document.getElementById('equitySparkline');
            if (!container) return;
            chartHandle = equityChart(container, []);
        }

        initChart();

        const client = createRunClient(runId, {
            onProgress: (progress) => {
                errorState.style.display = 'none';
                loading.style.display = 'none';

                document.getElementById('simClock').textContent = progress.simTimeUtc
                    ? new Date(progress.simTimeUtc).toISOString().replace('T', ' ').substring(0, 19) + ' UTC'
                    : '--';

                document.getElementById('progressFill').style.width = (progress.percent || 0) + '%';
                document.getElementById('kpiPercent').textContent = (progress.percent || 0).toFixed(1) + '%';
                document.getElementById('kpiSpeed').textContent = (progress.barsPerSec || 0).toFixed(1) + ' bars/s';
                document.getElementById('kpiEta').textContent = progress.etaSeconds != null
                    ? formatDuration(progress.etaSeconds * 1000)
                    : '--';
                document.getElementById('kpiElapsed').textContent = formatDuration(progress.wallElapsedMs || 0);

                document.getElementById('kpiEquity').textContent = (progress.equity || 0).toFixed(2);
                document.getElementById('kpiDailyDd').textContent = ((progress.dailyDdPct || 0) * 100).toFixed(2) + '%';
                document.getElementById('kpiMaxDd').textContent = ((progress.maxDdPct || 0) * 100).toFixed(2) + '%';
                document.getElementById('kpiOpen').textContent = progress.openPositions || 0;

                var counters = progress.counters || {};
                document.getElementById('countSignals').textContent = counters.signals || 0;
                document.getElementById('countOrders').textContent = counters.orders || 0;
                document.getElementById('countFills').textContent = counters.fills || 0;
                document.getElementById('countCloses').textContent = counters.closes || 0;
                document.getElementById('countRejections').textContent = counters.rejections || 0;
                document.getElementById('countBreaches').textContent = counters.breaches || 0;

                if ((counters.breaches || 0) > lastBreachCount) {
                    lastBreachCount = counters.breaches;
                    breachBanner.style.display = 'flex';
                    breachBanner.textContent = 'BREACH DETECTED';
                    setTimeout(() => { breachBanner.style.display = 'none'; }, 10000);
                }
                if (progress.governorState === 'SoftStop' || progress.governorState === 'HardStop') {
                    breachBanner.style.display = 'flex';
                    breachBanner.textContent = progress.governorState.toUpperCase() + (progress.governorReason ? ': ' + progress.governorReason : '');
                }

                if (progress.equity && chartHandle) {
                    equityPoints.push({
                        time: Math.floor(new Date(progress.simTimeUtc || Date.now()).getTime() / 1000),
                        equity: progress.equity
                    });
                    if (equityPoints.length <= 500) {
                        chartHandle.line.setData(equityPoints.map(p => ({ time: p.time, value: p.equity })));
                        chartHandle.chart.timeScale().fitContent();
                    }
                }

                if (progress.recentJournal && progress.recentJournal.length > 0) {
                    progress.recentJournal.forEach(j => {
                        var div = document.createElement('div');
                        div.className = 'journal-line journal-line--' + (j.event || '');
                        div.dataset.event = j.event;
                        var time = j.simTimeUtc ? new Date(j.simTimeUtc).toISOString().substring(11, 19) : '';
                        var symbol = j.symbol || '';
                        var extra = '';
                        try {
                            if (j.detailJson && j.detailJson !== '{}') {
                                var d = JSON.parse(j.detailJson);
                                if (d.equity) extra += ' eq=' + Number(d.equity).toFixed(2);
                                if (d.balance) extra += ' bal=' + Number(d.balance).toFixed(2);
                            }
                        } catch (e) { }
                        div.textContent = '[' + time + '] ' + (j.event || '') + ' ' + symbol + ' ' + (j.reason || '') + extra;
                        journalFeed.appendChild(div);
                    });
                    applyJournalFilter();
                    if (!journalPaused) {
                        journalFeed.scrollTop = journalFeed.scrollHeight;
                    }
                    while (journalFeed.children.length > 500) {
                        journalFeed.removeChild(journalFeed.firstChild);
                    }
                }
            },
            onDone: (progress) => {
                loading.style.display = 'none';
                errorState.style.display = 'none';
                completedCta.style.display = 'block';
                if (progress.status === 'completed') {
                    completedCta.querySelector('a').textContent = 'View Report';
                } else {
                    completedCta.querySelector('a').textContent = 'Run ' + (progress.status || 'finished');
                    completedCta.querySelector('a').style.color = 'var(--neg)';
                }
            },
            onStatus: (status) => {
                if (status === 'reconnecting' || status === 'disconnected') {
                    errorState.style.display = 'flex';
                    document.getElementById('errorMsg').textContent = status === 'reconnecting' ? 'Connection lost. Reconnecting...' : 'Disconnected';
                }
                if (status === 'connected') {
                    errorState.style.display = 'none';
                    fetch('/api/backtest/' + runId + '/status')
                        .then(r => r.json())
                        .then(s => {
                            if (s.status === 'completed' || s.status === 'failed') {
                                loading.style.display = 'none';
                                completedCta.style.display = 'block';
                                if (s.status === 'completed') {
                                    completedCta.querySelector('a').textContent = 'View Report';
                                } else {
                                    completedCta.querySelector('a').textContent = 'Run ' + s.status;
                                    completedCta.querySelector('a').style.color = 'var(--neg)';
                                }
                            }
                        }).catch(() => {});
                }
            }
        });

        client.start();
    </script>
}
