@page "/runs/{runId}/report"
@model ReportModel
@{
    ViewData["Title"] = "Backtest Report";
    ViewData["RunId"] = Model.RunId;
}
<h1>Backtest Report</h1>
<p style="color:var(--text-muted);margin-bottom:var(--sp-4)">Run @Model.RunId</p>

<div class="tabs" role="tablist">
    <button id="tab-btn-summary" class="tab active" role="tab" aria-selected="true" onclick="switchTab('summary')">Summary</button>
    <button id="tab-btn-journal" class="tab" role="tab" aria-selected="false" onclick="switchTab('journal')">Journal</button>
</div>

<div id="tab-summary">

<div class="grid">
    <div class="card"><h2>Net P&L</h2><div class="value @(Model.NetPnL >= 0 ? "positive" : "negative")">@Model.NetPnL.ToString("N2")</div></div>
    <div class="card"><h2>Return</h2><div class="value @(Model.ReturnPct >= 0 ? "positive" : "negative")">@Model.ReturnPct.ToString("P2")</div></div>
    <div class="card"><h2>Max DD</h2><div class="value negative">@Model.MaxDdPct.ToString("P2")</div></div>
    <div class="card"><h2>Win Rate</h2><div class="value">@Model.WinRatePct.ToString("F1")%</div></div>
    <div class="card"><h2>Total Trades</h2><div class="value">@Model.TotalTrades</div></div>
    <div class="card"><h2>Profit Factor</h2><div class="value">@(Model.ProfitFactor == decimal.MaxValue ? "∞" : Model.ProfitFactor > 0 ? Model.ProfitFactor.ToString("F2") : "--")</div></div>
</div>

<div class="card">
    <h2>Run Facts</h2>
    <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(150px, 1fr))">
        <div class="kpi"><span class="kpi-label">Duration</span><span class="kpi-value num" style="font-size:var(--fs-lg)">@Model.DurationDisplay</span></div>
        <div class="kpi"><span class="kpi-label">Bars/sec</span><span class="kpi-value num" style="font-size:var(--fs-lg)">@Model.BarsPerSec.ToString("F1")</span></div>
        <div class="kpi"><span class="kpi-label">Date Range</span><span class="kpi-value num" style="font-size:var(--fs-base)">@Model.DateRange</span></div>
        <div class="kpi"><span class="kpi-label">Initial Balance</span><span class="kpi-value num" style="font-size:var(--fs-lg)">@Model.InitialBalance.ToString("N0")</span></div>
    </div>
</div>

<div class="card">
    <h2>Equity + Drawdown</h2>
    <div id="equityDdChart" style="height:400px"></div>
</div>

@if (Model.HasBreaches)
{
    <div class="card" style="border-color:var(--crit)">
        <h2 style="color:var(--crit)">Compliance</h2>
        <p style="color:var(--neg)">Breach detected. @Model.BreachSummary</p>
    </div>
}
else
{
    <div class="card">
        <h2>Compliance</h2>
        <p class="status-ok">No breaches</p>
    </div>
}

<div class="card">
    <h2>Strategy Funnel</h2>
    <table>
        <thead><tr><th>Strategy</th><th>Signals</th><th>Orders</th><th>Fills</th><th>Trades</th><th>Win Rate</th></tr></thead>
        <tbody>
        @foreach (var s in Model.FunnelRows)
        {
            <tr>
                <td>@s.StrategyId</td>
                <td class="num">@s.Signals</td>
                <td class="num">@s.Orders</td>
                <td class="num">@s.Fills</td>
                <td class="num">@s.Closes</td>
                <td class="num">@(s.WinRate > 0 ? s.WinRate.ToString("F1") + "%" : "--")</td>
            </tr>
        }
        </tbody>
    </table>
</div>

<div class="card">
    <h2>Trades</h2>
    <table>
        <thead><tr><th>Symbol</th><th>Direction</th><th>Lots</th><th>Entry</th><th>Exit</th><th>Net PnL</th><th>Exit Reason</th></tr></thead>
        <tbody>
        @foreach (var t in Model.TradeRows)
        {
            <tr>
                <td>@t.Symbol</td>
                <td>@t.Direction</td>
                <td class="num">@t.Lots.ToString("F4")</td>
                <td class="num">@t.EntryPrice.ToString("F5")</td>
                <td class="num">@t.ExitPrice.ToString("F5")</td>
                <td class="num @(t.NetPnL >= 0 ? "positive" : "negative")">@t.NetPnL.ToString("F2")</td>
                <td>@t.ExitReason</td>
            </tr>
        }
        </tbody>
    </table>
</div>

</div><!-- /#tab-summary -->

<div id="tab-journal" style="display:none">
    <div class="card">
        <h2>Journal Filters</h2>
        <div class="journal-filters" style="display:flex;gap:var(--sp-2);flex-wrap:wrap">
            <button class="tab active journal-kind-filter" data-kind="">All</button>
            <button class="tab journal-kind-filter" data-kind="SIGNAL">Signals</button>
            <button class="tab journal-kind-filter" data-kind="ORDER">Orders</button>
            <button class="tab journal-kind-filter" data-kind="FILL">Fills</button>
            <button class="tab journal-kind-filter" data-kind="CLOSE">Closes</button>
            <button class="tab journal-kind-filter" data-kind="REJECTED">Rejections</button>
            <button class="tab journal-kind-filter" data-kind="BREACH">Breaches</button>
        </div>
    </div>
    <div class="card">
        <h2>Journal</h2>
        <div id="journalFeed" class="journal-feed" style="max-height:70vh;overflow-y:auto" aria-live="polite">
            <div class="empty"><span class="empty-icon">~</span><span>Loading journal...</span></div>
        </div>
        <div style="display:flex;justify-content:center;margin-top:var(--sp-4)">
            <button id="journalLoadMore" class="tab" style="display:none" onclick="loadJournalPage()">Load More</button>
        </div>
        <div id="journalEnd" class="empty" style="display:none">
            <span class="empty-icon">-</span><span>End of journal</span>
        </div>
    </div>
</div><!-- /#tab-journal -->

@section Scripts {
    <script type="module">
        import { equityChart } from '/js/charts/index.js';
        const container = document.getElementById('equityDdChart');
        const points = @Html.Raw(Model.EquityCurveJson);
        if (points && points.length > 0) {
            equityChart(container, points);
        }
    </script>
    <script>
        // ── Tab switching ────
        function switchTab(name) {
            document.getElementById('tab-summary').style.display = name === 'summary' ? '' : 'none';
            document.getElementById('tab-journal').style.display = name === 'journal' ? '' : 'none';
            document.getElementById('tab-btn-summary').classList.toggle('active', name === 'summary');
            document.getElementById('tab-btn-summary').setAttribute('aria-selected', name === 'summary');
            document.getElementById('tab-btn-journal').classList.toggle('active', name === 'journal');
            document.getElementById('tab-btn-journal').setAttribute('aria-selected', name === 'journal');
        }

        // ── Journal ────
        (function() {
            const runId = '@Model.RunId';
            const feed = document.getElementById('journalFeed');
            const loadMoreBtn = document.getElementById('journalLoadMore');
            const endDiv = document.getElementById('journalEnd');
            const limit = 50;

            let activeKind = '';
            let maxSeq = 0;
            let loading = false;
            let exhausted = false;
            let hasInitialLoad = false;

            function badgeHtml(kind) {
                if (!kind) return '';
                var cls = 'pill';
                switch (kind) {
                    case 'SIGNAL':   cls += ' pill--cooling'; break;
                    case 'ORDER':    cls += ' pill--normal'; break;
                    case 'FILL':     cls += ' pill--normal'; break;
                    case 'CLOSE':    cls += ' pill--reduced'; break;
                    case 'REJECTED': cls += ' pill--hardstop'; break;
                    case 'BREACH':   cls += ' pill--hardstop'; break;
                    case 'GOVERNOR': cls += ' pill--softstop'; break;
                    default:         cls += ''; break;
                }
                return '<span class="' + cls + '">' + kind + '</span>';
            }

            function formatSimTime(utc) {
                return utc ? new Date(utc).toISOString().replace('T', ' ').substring(0, 19) : '';
            }

            function renderEvents(events) {
                if (events.length === 0) return;
                var html = '';
                for (var i = 0; i < events.length; i++) {
                    var e = events[i];
                    if (e.seq > maxSeq) maxSeq = e.seq;
                    var detail = '';
                    try {
                        if (e.detail && e.detail !== '{}') {
                            var d = JSON.parse(e.detail);
                            var parts = [];
                            for (var k in d) { if (d.hasOwnProperty(k)) parts.push(k + '=' + d[k]); }
                            detail = parts.join(', ');
                        }
                    } catch(ex) {}
                    html += '<tr>' +
                        '<td class="num" style="color:var(--text-muted)">' + e.seq + '</td>' +
                        '<td style="font-family:var(--font-mono);white-space:nowrap">' + formatSimTime(e.simTime) + '</td>' +
                        '<td>' + badgeHtml(e.kind) + '</td>' +
                        '<td>' + (e.symbol || '') + '</td>' +
                        '<td style="color:var(--text-muted)">' + (e.strategy || '') + '</td>' +
                        '<td style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">' + (e.reason || '') + ' ' + detail + '</td>' +
                        '</tr>';
                }
                feed.querySelector('table tbody').insertAdjacentHTML('beforeend', html);
            }

            function showEmpty() {
                feed.innerHTML = '<div class="empty"><span class="empty-icon">-</span><span>No journal events</span></div>';
            }

            function initTable() {
                feed.innerHTML = '<table><thead><tr>' +
                    '<th>Seq</th><th>SimTime</th><th>Kind</th><th>Symbol</th><th>Strategy</th><th>Detail</th>' +
                    '</tr></thead><tbody></tbody></table>';
            }

            async function loadJournalPage(reset) {
                if (loading) return;
                loading = true;
                loadMoreBtn.style.display = 'none';

                if (reset) {
                    maxSeq = 0;
                    exhausted = false;
                    initTable();
                }

                var url = '/api/backtest/' + runId + '/journal?limit=' + limit;
                if (activeKind) url += '&kind=' + encodeURIComponent(activeKind);
                if (maxSeq > 0) url += '&afterSeq=' + maxSeq;

                try {
                    var resp = await fetch(url);
                    if (!resp.ok) {
                        feed.innerHTML = '<div class="empty"><span class="empty-icon">!</span><span>Failed to load journal</span></div>';
                        return;
                    }
                    var events = await resp.json();
                    if (!hasInitialLoad && events.length === 0 && !reset) {
                        showEmpty();
                    }
                    if (events.length < limit) {
                        exhausted = true;
                        endDiv.style.display = 'flex';
                    } else {
                        exhausted = false;
                        endDiv.style.display = 'none';
                    }
                    renderEvents(events);
                    if (!exhausted) {
                        loadMoreBtn.style.display = '';
                    }
                    hasInitialLoad = true;
                } catch (err) {
                    feed.innerHTML = '<div class="empty"><span class="empty-icon">!</span><span>Error loading journal</span></div>';
                } finally {
                    loading = false;
                }
            }

            // Kind filter buttons
            document.querySelectorAll('.journal-kind-filter').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    document.querySelectorAll('.journal-kind-filter').forEach(function(b) { b.classList.remove('active'); });
                    btn.classList.add('active');
                    activeKind = btn.dataset.kind;
                    maxSeq = 0;
                    exhausted = false;
                    endDiv.style.display = 'none';
                    initTable();
                    loadJournalPage(true);
                });
            });

            // Initial load when Journal tab is first opened
            var initialLoadDone = false;
            document.getElementById('tab-btn-journal').addEventListener('click', function() {
                if (!initialLoadDone) {
                    initialLoadDone = true;
                    loadJournalPage(true);
                }
            });
        })();
    </script>
}
