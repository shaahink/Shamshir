@page "/backtests/detail"
@model TradingEngine.Web.Pages.Backtests.DetailModel
@{
    ViewData["Title"] = $"Backtest {Model.Run?.RunId}";
}
@if (Model.Run is null)
{
    <h1>Backtest not found</h1>
}
else
{
    <h1>Backtest @Model.Run.RunId</h1>
    <div style="margin-bottom:0.5rem;color:#888;">
        @Model.Run.Symbol @Model.Run.Period |
        @Model.Run.BacktestFrom.ToString("yyyy-MM-dd") to @Model.Run.BacktestTo.ToString("yyyy-MM-dd") |
        Initial: @Model.Run.InitialBalance.ToString("C")
        @if (!string.IsNullOrEmpty(Model.Run.AlgoHash))
        {
            <span style="margin-left:1rem;background:#333;color:#58a6ff;padding:0.1rem 0.4rem;border-radius:3px;font-size:0.8rem;">algo:@Model.Run.AlgoHash</span>
        }
    </div>

    <div style="margin-bottom:0.5rem;">
        Status: <strong>@Model.Run.Status</strong>
    </div>

    @if (!Model.IsActive)
    {
        <table class="table">
            <tr><td>Net Profit</td><td style="color:@(Model.Run.NetProfit > 0 ? "green" : "red")">@Model.Run.NetProfit.ToString("N2")</td></tr>
            <tr><td>Max Drawdown</td><td>@Model.Run.MaxDrawdownPct.ToString("P1")</td></tr>
            <tr><td>Total Trades</td><td>@Model.Run.TotalTrades</td></tr>
            <tr><td>Winning Trades</td><td>@Model.Run.WinningTrades</td></tr>
            <tr><td>Win Rate</td><td>@Model.Run.WinRatePct.ToString("P1")</td></tr>
        </table>
    }
}
