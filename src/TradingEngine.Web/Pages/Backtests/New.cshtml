@page "/backtests/new"
@model NewBacktestModel
@{
    ViewData["Title"] = "New Backtest";
}
<h1>New Backtest</h1>

@if (!string.IsNullOrEmpty(Model.PreflightMessage))
{
    <div style="background:#fff3cd;border:1px solid #ffc107;color:#856404;padding:1rem;margin-bottom:1rem;border-radius:4px;">
        <strong>Preflight failed:</strong> @Model.PreflightMessage
    </div>
}

<div style="margin-bottom:1rem;color:#8b949e;font-size:0.85rem;">
    Data source: <strong>@(Model.UseCTrader ? "cTrader NetMQ" : "DB Replay")</strong>
</div>

<form id="backtestForm" onsubmit="submitBacktest(event)" style="max-width:700px">
    <div class="card">
        <h2>Symbols</h2>
        <div style="display:flex;flex-wrap:wrap;gap:var(--sp-1)">
            @foreach (var sym in new[] { "EURUSD", "GBPUSD", "USDJPY", "GBPJPY", "XAUUSD", "AUDUSD", "USDCHF", "USDCAD", "NZDUSD", "EURGBP", "EURJPY", "XAGUSD" })
            {
                <label style="display:flex;align-items:center;gap:4px;padding:2px 6px;cursor:pointer;font-size:var(--fs-sm);border:1px solid var(--border);border-radius:var(--radius-sm)">
                    <input type="checkbox" name="symbols" value="@sym" @(sym == "EURUSD" ? "checked" : "") /> @sym
                </label>
            }
        </div>
    </div>
    <div class="card">
        <h2>Timeframes</h2>
        <div style="display:flex;gap:var(--sp-2);flex-wrap:wrap">
            @foreach (var tf in new[] { "H1", "H4", "D1", "M15", "M5", "M1" })
            {
                <label style="display:flex;align-items:center;gap:4px;padding:2px 8px;cursor:pointer;font-size:var(--fs-sm);border:1px solid var(--border);border-radius:var(--radius-sm)">
                    <input type="checkbox" name="periods" value="@tf" @(tf == "H1" ? "checked" : "") /> @tf
                </label>
            }
        </div>
    </div>
    @if (Model.StrategyIds.Length > 0)
    {
        <div class="card">
            <h2>Strategies (empty = all active)</h2>
            <div style="display:flex;flex-wrap:wrap;gap:var(--sp-1)">
                @foreach (var sid in Model.StrategyIds)
                {
                    <label style="display:flex;align-items:center;gap:4px;padding:2px 6px;cursor:pointer;font-size:var(--fs-xs);border:1px solid var(--border);border-radius:var(--radius-sm)">
                        <input type="checkbox" name="strategyIds" value="@sid" /> @sid
                    </label>
                }
            </div>
        </div>
    }
    <div class="card">
        <h2>Date Range</h2>
        <div style="display:flex;gap:var(--sp-2);flex-wrap:wrap">
            <button type="button" class="tab" onclick="setDateRange(30)">Last Month</button>
            <button type="button" class="tab" onclick="setDateRange(90)">Last Quarter</button>
            <button type="button" class="tab" onclick="setDateRange(365)">Last Year</button>
        </div>
        <div style="display:flex;gap:var(--sp-2);margin-top:var(--sp-3)">
            <div style="flex:1"><label style="color:var(--text-muted);font-size:var(--fs-xs)">Start</label><input type="date" id="startDate" style="width:100%;padding:var(--sp-2);background:var(--surface);color:var(--text);border:1px solid var(--border);border-radius:var(--radius-sm)" /></div>
            <div style="flex:1"><label style="color:var(--text-muted);font-size:var(--fs-xs)">End</label><input type="date" id="endDate" style="width:100%;padding:var(--sp-2);background:var(--surface);color:var(--text);border:1px solid var(--border);border-radius:var(--radius-sm)" /></div>
        </div>
    </div>
    <div class="card">
        <h2>Initial Balance</h2>
        <input type="number" id="balance" value="100000" min="100" step="100" style="width:100%;padding:var(--sp-2);background:var(--surface);color:var(--text);border:1px solid var(--border);border-radius:var(--radius-sm)" />
    </div>
    <div style="text-align:right;padding:var(--sp-4)">
        <button type="submit" style="background:var(--accent);color:var(--text-strong);border:none;padding:var(--sp-2) var(--sp-5);border-radius:var(--radius);font-size:var(--fs-lg);cursor:pointer;font-weight:600">Start Backtest</button>
    </div>
</form>

<div id="result" style="display:none;text-align:center;padding:var(--sp-5)">
    <div class="empty"><span class="empty-icon">--</span><span id="resultMsg"></span></div>
</div>

@section Scripts {
    <script type="module">
        function setDateRange(days) {
            const end = new Date();
            const start = new Date();
            start.setDate(start.getDate() - days);
            document.getElementById('startDate').value = start.toISOString().split('T')[0];
            document.getElementById('endDate').value = end.toISOString().split('T')[0];
        }

        setDateRange(90);
        window.setDateRange = setDateRange;

        window.submitBacktest = async function(e) {
            e.preventDefault();

            const getChecked = (name) => {
                const boxes = document.querySelectorAll('input[name="' + name + '"]:checked');
                return Array.from(boxes).map(cb => cb.value).join(',');
            };

            const symbols = getChecked('symbols') || 'EURUSD';
            const periods = getChecked('periods') || 'H1';
            const strategyIds = getChecked('strategyIds');

            const payload = {
                symbol: symbols.split(',')[0],
                symbols: symbols,
                period: (periods.split(',')[0] || 'H1').toLowerCase(),
                periods: periods,
                start: document.getElementById('startDate').value + 'T00:00:00',
                end: document.getElementById('endDate').value + 'T00:00:00',
                balance: parseInt(document.getElementById('balance').value),
                strategyIds: strategyIds || null
            };

            const result = document.getElementById('result');
            const msg = document.getElementById('resultMsg');
            result.style.display = 'block';
            msg.textContent = 'Starting backtest...';

            try {
                const r = await fetch('/api/backtest/start', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const data = await r.json();
                if (data.runId) {
                    msg.textContent = 'Backtest started. Redirecting to monitor...';
                    setTimeout(() => { window.location.href = '/runs/' + data.runId + '/monitor'; }, 1000);
                } else {
                    msg.textContent = 'Failed: ' + (data.error || 'unknown error');
                }
            } catch (e) {
                msg.textContent = 'Error: ' + e.message;
            }
        };
    </script>
}
