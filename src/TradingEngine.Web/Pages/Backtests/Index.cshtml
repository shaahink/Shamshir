@page
@model TradingEngine.Web.Pages.Backtests.IndexModel
@{
    ViewData["Title"] = "Backtests";
}

<h1>Backtests</h1>

<a class="btn" href="/backtests/run" style="margin-bottom:1rem;display:inline-block;padding:0.5rem 1rem;background:#1a73e8;color:#fff;text-decoration:none;border-radius:4px;">New Backtest</a>

@if (Model.Runs.Count == 0)
{
    <p>No backtests have been run yet.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Run</th>
                <th>Symbol</th>
                <th>Period</th>
                <th>Status</th>
                <th>Started</th>
                <th>Profit</th>
                <th>Max DD%</th>
                <th>Trades</th>
                <th>Win Rate</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var run in Model.Runs.OrderByDescending(r => r.StartedAt))
            {
                <tr>
                    <td><a href="/backtest/@run.RunId">@run.RunId</a></td>
                    <td>-</td>
                    <td>-</td>
                    <td>
                        <span style="color:@(run.Status == "completed" ? "green" : run.Status == "failed" ? "red" : "orange")">
                            @run.Status
                        </span>
                    </td>
                    <td>@run.StartedAt.ToString("MM/dd HH:mm")</td>
                    <td style="color:@(run.Result?.NetProfit > 0 ? "green" : "red")">
                        @run.Result?.NetProfit.ToString("N2")
                    </td>
                    <td>@(run.Result?.MaxDrawdownPct.ToString("P1"))</td>
                    <td>@run.Result?.TotalTrades</td>
                    <td>@(run.Result?.WinRatePct.ToString("P1"))</td>
                </tr>
            }
        </tbody>
    </table>
}
