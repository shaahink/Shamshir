@page
@model TradingEngine.Web.Pages.Backtests.RunModel
@{
    ViewData["Title"] = "New Backtest";
}

<h1>New Backtest</h1>

@if (!Model.CredentialsConfigured)
{
    <div style="background:#fff3cd;border:1px solid #ffc107;color:#856404;padding:1rem;margin-bottom:1rem;border-radius:4px;">
        <strong>Warning:</strong> CTrader credentials are not configured.
        Set via <code>dotnet user-secrets set CTrader:CtId "your-ctid"</code>,
        <code>CTrader:PwdFile "path\to\file.pwd"</code>, and
        <code>CTrader:Account "your-account"</code> in the
        <code>src/TradingEngine.Web</code> directory.
        Backtests will fail without these.
    </div>
}

<form method="post" class="backtest-form">
    <div class="form-group">
        <label>Symbols (check all you want to trade, first checked = primary)</label>
        <div class="checkbox-grid">
            <label><input type="checkbox" name="SelectedSymbols" value="EURUSD" checked="checked" /> EURUSD</label>
            <label><input type="checkbox" name="SelectedSymbols" value="GBPUSD" /> GBPUSD</label>
            <label><input type="checkbox" name="SelectedSymbols" value="USDJPY" /> USDJPY</label>
            <label><input type="checkbox" name="SelectedSymbols" value="GBPJPY" /> GBPJPY</label>
            <label><input type="checkbox" name="SelectedSymbols" value="XAUUSD" /> XAUUSD</label>
            <label><input type="checkbox" name="SelectedSymbols" value="AUDUSD" /> AUDUSD</label>
            <label><input type="checkbox" name="SelectedSymbols" value="USDCHF" /> USDCHF</label>
            <label><input type="checkbox" name="SelectedSymbols" value="USDCAD" /> USDCAD</label>
            <label><input type="checkbox" name="SelectedSymbols" value="NZDUSD" /> NZDUSD</label>
            <label><input type="checkbox" name="SelectedSymbols" value="EURGBP" /> EURGBP</label>
            <label><input type="checkbox" name="SelectedSymbols" value="EURJPY" /> EURJPY</label>
            <label><input type="checkbox" name="SelectedSymbols" value="XAGUSD" /> XAGUSD</label>
        </div>
    </div>

    <div class="form-group">
        <label>Timeframes (check all you want)</label>
        <div class="checkbox-inline">
            <label><input type="checkbox" name="SelectedPeriods" value="H1" checked="checked" /> H1</label>
            <label><input type="checkbox" name="SelectedPeriods" value="M15" /> M15</label>
            <label><input type="checkbox" name="SelectedPeriods" value="M5" /> M5</label>
            <label><input type="checkbox" name="SelectedPeriods" value="M1" /> M1</label>
            <label><input type="checkbox" name="SelectedPeriods" value="D1" /> D1</label>
            <label><input type="checkbox" name="SelectedPeriods" value="H4" /> H4</label>
        </div>
    </div>

    <div class="form-group">
        <label for="StartDate">Start Date</label>
        <input type="date" id="StartDate" asp-for="StartDate" />
    </div>

    <div class="form-group">
        <label for="EndDate">End Date</label>
        <input type="date" id="EndDate" asp-for="EndDate" />
    </div>

    <div class="form-group">
        <label for="Balance">Initial Balance ($)</label>
        <input type="number" id="Balance" asp-for="Balance" step="1000" />
    </div>

    <button type="submit" class="btn" style="padding:0.5rem 1rem;background:#1a73e8;color:#fff;border:none;border-radius:4px;cursor:pointer;">
        Run Backtest
    </button>
</form>

<style>
    .backtest-form { max-width: 600px; }
    .form-group { margin-bottom: 1rem; }
    .form-group > label:first-child { display: block; margin-bottom: 0.3rem; font-weight: bold; }
    .form-group input[type="date"], .form-group input[type="number"] { width: 100%%; padding: 0.4rem; box-sizing: border-box; }
    .checkbox-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.3rem; }
    .checkbox-grid label { display: flex; align-items: center; gap: 0.3rem; cursor: pointer; }
    .checkbox-inline { display: flex; gap: 1rem; flex-wrap: wrap; }
    .checkbox-inline label { display: flex; align-items: center; gap: 0.3rem; cursor: pointer; }
</style>
