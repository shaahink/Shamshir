@page "/backtest/{runId}"
@model TradingEngine.Web.Pages.Backtests.ProgressModel
@{
    ViewData["Title"] = $"Backtest {Model.RunId}";
}

<h1>Backtest @Model.RunId</h1>

<div style="margin-bottom:0.5rem;color:#888;">
    @Model.State?.Symbol @Model.State?.Period |
    Started: @Model.State?.StartedAt.ToString("MMM dd, HH:mm UTC")
</div>

@if (Model.State?.Status == "failed" && !string.IsNullOrEmpty(Model.State?.Error))
{
    <div id="errorBox" style="background:#f8d7da;border:1px solid#f5c6cb;color:#721c24;padding:1rem;margin-bottom:1rem;border-radius:4px;">
        <strong>Error:</strong> <span id="errorText">@Model.State.Error</span>
    </div>
}
else
{
    <div id="errorBox" style="display:none;background:#f8d7da;border:1px solid#f5c6cb;color:#721c24;padding:1rem;margin-bottom:1rem;border-radius:4px;">
        <strong>Error:</strong> <span id="errorText"></span>
    </div>
}

<div id="status" style="font-size:1.2rem;margin-bottom:1rem;">
    Status: <span id="statusText">@Model.State?.Status</span>
</div>

<div id="result" style="display:@(Model.State?.Status == "completed" ? "block" : "none");margin-bottom:1rem;">
    @if (Model.State?.Result is not null)
    {
        <table class="table">
            <tr><td>Net Profit</td><td style="color:@(Model.State.Result.NetProfit > 0 ? "green" : "red")">@Model.State.Result.NetProfit.ToString("N2")</td></tr>
            <tr><td>Max Drawdown</td><td>@Model.State.Result.MaxDrawdownPct.ToString("P1")</td></tr>
            <tr><td>Total Trades</td><td>@Model.State.Result.TotalTrades</td></tr>
            <tr><td>Winning Trades</td><td>@Model.State.Result.WinningTrades</td></tr>
            <tr><td>Win Rate</td><td>@Model.State.Result.WinRatePct.ToString("P1")</td></tr>
        </table>
        <a href="/trades" class="btn" style="display:inline-block;padding:0.5rem 1rem;background:#1a73e8;color:#fff;text-decoration:none;border-radius:4px;">View Trades</a>
    }
</div>

<h3>Log</h3>
<pre id="log" style="background:#1e1e1e;color:#d4d4d4;padding:1rem;border-radius:4px;max-height:400px;overflow-y:auto;font-size:0.85rem;"></pre>

@section Scripts {
<script>
    const runId = '@Model.RunId';
    const logEl = document.getElementById('log');
    const statusText = document.getElementById('statusText');
    const resultDiv = document.getElementById('result');
    const errorBox = document.getElementById('errorBox');
    const errorText = document.getElementById('errorText');

    const evtSource = new EventSource(`/api/backtest/${runId}/stream`);
    evtSource.onmessage = function(e) {
        const data = JSON.parse(e.data);
        if (data.line) {
            logEl.textContent += data.line + '\n';
            logEl.scrollTop = logEl.scrollHeight;
        }
        if (data.done) {
            statusText.textContent = data.status;
            if (data.status === 'completed') {
                resultDiv.style.display = 'block';
            }
            if (data.status === 'failed') {
                logEl.textContent += '\n[Backtest failed. See error above.]\n';
                if (data.error) {
                    errorBox.style.display = 'block';
                    errorText.textContent = data.error;
                }
            }
            // Fetch status to get result with report path
            fetch(`/api/backtest/${runId}/status`)
                .then(r => r.json())
                .then(s => {
                    if (s.result) {
                        const links = document.getElementById('resultLinks');
                        if (s.result.totalTrades > 0 && !links) {
                            const div = document.createElement('div');
                            div.id = 'resultLinks';
                            div.style.marginTop = '0.5rem';
                            div.innerHTML = '<a href="/trades" class="btn" style="display:inline-block;padding:0.5rem 1rem;background:#1a73e8;color:#fff;text-decoration:none;border-radius:4px;">View Trades</a>';
                            resultDiv.appendChild(div);
                        }
                    }
                });
            evtSource.close();
        }
    };
    evtSource.onerror = function() {
        if (evtSource.readyState === EventSource.CLOSED) {
            logEl.textContent += '\n[Connection closed. Backtest has finished.]\n';
        }
    };
</script>
}
