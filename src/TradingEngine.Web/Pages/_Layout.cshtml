<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Shamshir Trading Engine</title>
    <link rel="stylesheet" href="/css/site.css" />
    <script src="https://unpkg.com/lightweight-charts/dist/lightweight-charts.standalone.production.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8/dist/browser/signalr.min.js"></script>
</head>
<body>
    <div class="app-shell">
        <nav class="sidebar" aria-label="Site navigation">
            <a class="brand" href="/">Shamshir</a>
            <div class="nav-group" role="group" aria-label="Live">
                <div class="nav-group-title">LIVE</div>
                <a href="/" class="nav-item">Engine</a>
                <a href="/compliance" class="nav-item">Compliance</a>
            </div>
            <div class="nav-group" role="group" aria-label="Research">
                <div class="nav-group-title">RESEARCH</div>
                <a href="/backtests/new" class="nav-item">New Backtest</a>
                <a href="/runs" class="nav-item">Runs</a>
                <a href="/trades" class="nav-item">Trades</a>
            </div>
            <div class="nav-group" role="group" aria-label="Library">
                <div class="nav-group-title">LIBRARY</div>
                <a href="/strategies" class="nav-item">Strategies</a>
                <a href="/events" class="nav-item">Events</a>
            </div>
        </nav>
        <div class="main-area">
            @if (ViewData["RunId"] is string runId)
            {
                @await Html.PartialAsync("Shared/_RunNav", runId)
            }
            <main class="content">
                @RenderBody()
            </main>
        </div>
    </div>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
