@page
@model PerformanceModel
@{
    ViewData["Title"] = "Performance";
}
<h1>Performance</h1>
<div class="grid">
    <div class="card"><h2>Total Trades</h2><div class="value">@Model.TotalTrades</div></div>
    <div class="card"><h2>Win Rate</h2><div class="value">@Model.WinRate.ToString("P1")</div></div>
    <div class="card"><h2>Net PnL</h2><div class="value @(Model.NetPnL >= 0 ? "positive" : "negative")">@Model.NetPnL.ToString("F2")</div></div>
    <div class="card"><h2>Avg Hold Hours</h2><div class="value">@Model.AvgHoldHours.ToString("F1")</div></div>
</div>
<div class="card">
    <h2>Equity Curve</h2>
    <canvas id="perfChart" height="300"></canvas>
</div>
@section Scripts {
    <script>
        fetch('/api/equity')
            .then(r => r.json())
            .then(data => renderEquityCurve('perfChart', data))
            .catch(() => {});
    </script>
}
