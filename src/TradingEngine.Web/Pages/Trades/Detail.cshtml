@page "/trades/{id:guid}"
@model TradeDetailModel
@{
    ViewData["Title"] = $"Trade {Model.Trade?.Id.ToString()[..8]}";
}
@if (Model.Trade is null)
{
    <div class="empty">
        <span class="empty-icon">--</span>
        <span>Trade not found</span>
    </div>
}
else
{
    <h1>Trade @Model.Trade.Id.ToString()[..8]</h1>

    <div class="tabs">
        <button class="tab active">Detail</button>
    </div>

    <div class="grid">
        <div class="card"><h2>Symbol</h2><div class="value">@Model.Trade.Symbol</div></div>
        <div class="card"><h2>Direction</h2><div class="value">@Model.Trade.Direction</div></div>
        <div class="card"><h2>Lots</h2><div class="value num">@Model.Trade.Lots.ToString("F2")</div></div>
        <div class="card"><h2>Net PnL</h2><div class="value num @(Model.Trade.NetPnLAmount >= 0 ? "positive" : "negative")">@Model.Trade.NetPnLAmount.ToString("F2")</div></div>
    </div>
    <div class="grid">
        <div class="card"><h2>Entry</h2><div class="value num">@Model.Trade.EntryPrice.ToString("F5")</div></div>
        <div class="card"><h2>Exit</h2><div class="value num">@Model.Trade.ExitPrice.ToString("F5")</div></div>
        <div class="card"><h2>SL</h2><div class="value num">@Model.Trade.StopLoss.ToString("F5")</div></div>
        <div class="card"><h2>TP</h2><div class="value num">@(Model.Trade.TakeProfit?.ToString("F5") ?? "N/A")</div></div>
    </div>
    <div class="grid">
        <div class="card"><h2>R Multiple</h2><div class="value num @(Model.Trade.RMultiple >= 0 ? "positive" : "negative")">@Model.Trade.RMultiple.ToString("F2")</div></div>
        <div class="card"><h2>Exit Reason</h2><div class="value">@Model.Trade.ExitReason</div></div>
        <div class="card"><h2>Holding Time</h2><div class="value num">@Model.Trade.DurationSeconds.ToString("F0")s</div></div>
        <div class="card"><h2>Opening</h2><div class="value num" style="font-size:var(--fs-base)">@Model.Trade.OpenedAtUtc.ToString("yyyy-MM-dd HH:mm")</div></div>
    </div>

    <div class="card">
        <h2>Price Chart</h2>
        <div id="tradeChart" style="height:400px"></div>
    </div>

    <div class="grid">
        <div class="card"><h2>MAE</h2><div class="value num negative">@Model.Trade.MaxAdverseExcursion.ToString("F1") pips</div></div>
        <div class="card"><h2>MFE</h2><div class="value num positive">@Model.Trade.MaxFavorableExcursion.ToString("F1") pips</div></div>
        <div class="card"><h2>Gross PnL</h2><div class="value num @(Model.Trade.GrossPnLAmount >= 0 ? "positive" : "negative")">@Model.Trade.GrossPnLAmount.ToString("F2")</div></div>
        <div class="card"><h2>Commission</h2><div class="value num">@Model.Trade.CommissionAmount.ToString("F2")</div></div>
    </div>

    @section Scripts {
        <script type="module">
            import { candleChart } from '/js/charts/index.js';
            const container = document.getElementById('tradeChart');
            const bars = @Html.Raw(Model.ChartBarsJson ?? "[]");
            const entryPrice = @Model.Trade.EntryPrice;
            const exitPrice = @Model.Trade.ExitPrice;
            const slPrice = @Model.Trade.StopLoss;
            const tpPrice = @(Model.Trade.TakeProfit?.ToString() ?? "null");

            if (container && bars.length > 0) {
                const c = candleChart(container, bars);
                c.addPriceLine('Entry', entryPrice, '#58a6ff');
                c.addPriceLine('Exit', exitPrice, Model.Trade.NetPnLAmount >= 0 ? '#3fb950' : '#f85149');
                c.addPriceLine('SL', slPrice, '#f85149');
                if (tpPrice !== null) c.addPriceLine('TP', tpPrice, '#3fb950');

                c.addMarkers([
                    { time: bars[0]?.time, position: 'inBar', color: '#58a6ff', shape: 'circle', text: 'E' },
                    { time: bars[bars.length-1]?.time, position: 'inBar', color: Model.Trade.NetPnLAmount >= 0 ? '#3fb950' : '#f85149', shape: 'circle', text: 'X' }
                ]);
            }
        </script>
    }
}
