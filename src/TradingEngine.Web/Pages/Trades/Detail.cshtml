@page "/trades/{id:guid}"
@model TradeDetailModel
@{
    ViewData["Title"] = $"Trade {Model.Trade?.Id.ToString()[..8]}";
}
@if (Model.Trade is null)
{
    <div class="empty">
        <span class="empty-icon">--</span>
        <span>Trade not found</span>
    </div>
}
else
{
    var t = Model.Trade;
    <h1>Trade @t.Id.ToString()[..8]</h1>

    <div class="grid" style="margin-bottom:var(--sp-3)">
        <div class="kpi"><span class="kpi-label">Symbol</span><span class="kpi-value">@t.Symbol</span></div>
        <div class="kpi"><span class="kpi-label">Direction</span><span class="kpi-value @(t.Direction == "Long" ? "positive" : "negative")">@t.Direction</span></div>
        <div class="kpi"><span class="kpi-label">Strategy</span><span class="kpi-value" style="font-size:var(--fs-sm)">@(string.IsNullOrEmpty(t.StrategyId) ? "--" : t.StrategyId)</span></div>
        <div class="kpi"><span class="kpi-label">Lots</span><span class="kpi-value">@t.Lots.ToString("F2")</span></div>
    </div>
    <div class="grid" style="margin-bottom:var(--sp-3)">
        <div class="kpi"><span class="kpi-label">Entry</span><span class="kpi-value">@t.EntryPrice.ToString("F5")</span></div>
        <div class="kpi"><span class="kpi-label">Exit</span><span class="kpi-value">@t.ExitPrice.ToString("F5")</span></div>
        <div class="kpi"><span class="kpi-label">SL</span><span class="kpi-value">@t.StopLoss.ToString("F5")</span></div>
        <div class="kpi"><span class="kpi-label">TP</span><span class="kpi-value">@(t.TakeProfit?.ToString("F5") ?? "--")</span></div>
    </div>
    <div class="grid" style="margin-bottom:var(--sp-3)">
        <div class="kpi"><span class="kpi-label">Net PnL</span><span class="kpi-value @(t.NetPnLAmount >= 0 ? "positive" : "negative")">@t.NetPnLAmount.ToString("F2")</span></div>
        <div class="kpi"><span class="kpi-label">R Multiple</span><span class="kpi-value">@t.RMultiple.ToString("F2")</span></div>
        <div class="kpi"><span class="kpi-label">Exit Reason</span><span class="kpi-value">@t.ExitReason</span></div>
        <div class="kpi"><span class="kpi-label">Duration</span><span class="kpi-value">@TimeSpan.FromSeconds(t.DurationSeconds).ToString(@"hh\:mm\:ss")</span></div>
    </div>
    <div class="grid" style="margin-bottom:var(--sp-3)">
        <div class="kpi"><span class="kpi-label">PnL (pips)</span><span class="kpi-value @(t.PnLPips >= 0 ? "positive" : "negative")">@t.PnLPips.ToString("F1")</span></div>
        <div class="kpi"><span class="kpi-label">Max Adverse (pips)</span><span class="kpi-value">@t.MaxAdverseExcursion.ToString("F1")</span></div>
        <div class="kpi"><span class="kpi-label">Max Favorable (pips)</span><span class="kpi-value">@t.MaxFavorableExcursion.ToString("F1")</span></div>
        <div class="kpi"><span class="kpi-label">Swap</span><span class="kpi-value">@t.SwapAmount.ToString("F2")</span></div>
    </div>

    @if (Model.HasAccountContext)
    {
        <div class="grid" style="margin-bottom:var(--sp-3)">
            <div class="kpi"><span class="kpi-label">Balance Before</span><span class="kpi-value">@Model.BalanceBefore.ToString("F2")</span></div>
            <div class="kpi"><span class="kpi-label">Balance After</span><span class="kpi-value @(Model.BalanceAfter >= Model.BalanceBefore ? "positive" : "negative")">@Model.BalanceAfter.ToString("F2")</span></div>
            <div class="kpi"><span class="kpi-label">Gross PnL</span><span class="kpi-value @(t.GrossPnLAmount >= 0 ? "positive" : "negative")">@t.GrossPnLAmount.ToString("F2")</span></div>
            <div class="kpi"><span class="kpi-label">Commission</span><span class="kpi-value">@t.CommissionAmount.ToString("F2")</span></div>
        </div>
    }

    <div class="card" style="margin-bottom:var(--sp-3)">
        <h2>Price Chart</h2>
        @if (Model.HasRealBars && Model.ChartBarsJson is not null)
        {
            <div id="tradeChart" style="height:400px"></div>
        }
        else
        {
            <div class="empty">
                <span class="empty-icon">--</span>
                <span>No price data for this window</span>
            </div>
        }
    </div>

    @section Scripts {
        @if (Model.HasRealBars && Model.ChartBarsJson is not null)
        {
            <script type="module">
                import { candleChart } from '/js/charts/index.js';

                const bars = @Html.Raw(Model.ChartBarsJson);
                const container = document.getElementById('tradeChart');
                if (container && bars.length > 0) {
                    const chart = window.LightweightCharts.createChart(container, {
                        layout: { background: { type: 'solid', color: '#0d1117' }, textColor: '#8b949e' },
                        grid: { vertLines: { color: '#21262d' }, horzLines: { color: '#21262d' } },
                        width: container.clientWidth,
                        height: 400
                    });
                    const series = chart.addCandlestickSeries({
                        upColor: '#3fb950', downColor: '#f85149', borderVisible: false,
                        wickUpColor: '#3fb950', wickDownColor: '#f85149'
                    });
                    series.setData(bars);

                    series.createPriceLine({ price: @t.EntryPrice, color: '#58a6ff', lineWidth: 2, lineStyle: 2, axisLabelVisible: true, title: 'Entry' });
                    series.createPriceLine({ price: @t.ExitPrice, color: '#d29922', lineWidth: 2, lineStyle: 2, axisLabelVisible: true, title: 'Exit' });
                    series.createPriceLine({ price: @t.StopLoss, color: '#f85149', lineWidth: 1, lineStyle: 1, axisLabelVisible: true, title: 'SL' });
                    @if (t.TakeProfit is not null)
                    {
                        @:series.createPriceLine({ price: @t.TakeProfit, color: '#3fb950', lineWidth: 1, lineStyle: 1, axisLabelVisible: true, title: 'TP' });
                    }

                    chart.timeScale().fitContent();
                }
            </script>
        }
    }
}
