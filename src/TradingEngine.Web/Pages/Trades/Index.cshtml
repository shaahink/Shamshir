@page
@model TradesIndexModel
@{
    ViewData["Title"] = "Trades";
}
<h1>Trades</h1>
<table>
    <thead>
        <tr>
            <th>Symbol</th>
            <th>Direction</th>
            <th>Lots</th>
            <th>Entry</th>
            <th>Exit</th>
            <th>PnL</th>
            <th>R Multiple</th>
            <th>Exit Reason</th>
            <th>Date</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var trade in Model.Trades)
        {
            <tr onclick="window.location='/trades/@trade.Id'">
                <td>@trade.Symbol</td>
                <td>@trade.Direction</td>
                <td>@trade.Lots</td>
                <td>@trade.EntryPrice.ToString("F5")</td>
                <td>@trade.ExitPrice.ToString("F5")</td>
                <td class="@(trade.NetPnLAmount >= 0 ? "positive" : "negative")">
                    @trade.NetPnLAmount.ToString("F2")
                </td>
                <td>@trade.RMultiple.ToString("F2")</td>
                <td>@trade.ExitReason</td>
                <td>@trade.ClosedAtUtc.ToString("yyyy-MM-dd")</td>
            </tr>
        }
    </tbody>
</table>
@if (Model.TotalPages > 1)
{
    <div class="pagination">
        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <a href="/trades?page=@i">@i</a>
        }
    </div>
}
