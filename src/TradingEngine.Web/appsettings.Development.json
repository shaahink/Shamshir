{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": "Debug",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/web-dev-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 3,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{Level:u3}] {Message:lj} {Exception}{NewLine}"
        }
      }
    ]
  },
  "Dev": {
    "NgServe": false
  },
  "Persistence": {
    "DbPath": "data/trading.db"
  },
  "Engine": {
    "Mode": "Backtest",
    "ActiveStrategyIds": "",
    "Diagnostics": {
      "Enabled": true
    }
  },
  "CTrader": {
    "Comment": "To test different symbols, change Symbol/Symbols. Supported: EURUSD, GBPUSD, USDJPY, GBPJPY, XAUUSD",
    "CtId": "seankiaa",
    "PwdFile": "C:\\Users\\shahi\\Documents\\ctrader.pwd",
    "Account": "5834367",
    "UseForBacktest": "false",
    "StartEngineSubprocess": "true",
    "Symbol": "EURUSD",
    "Symbols": "EURUSD"
  }
}
