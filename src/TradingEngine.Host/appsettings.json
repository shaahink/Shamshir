{
  "Engine": {
    "Mode": "Backtest",
    "ActiveRiskProfileId": "standard",
    "ActiveStrategyIds": "trend-breakout,ema-alignment,mean-reversion,session-breakout",
    "PropFirmRuleSetId": "ftmo-standard",
    "Broker": {
      "PipeName": "trading-engine",
      "ConnectionTimeoutMs": 5000,
      "ReconnectDelayMs": 1000
    }
  },
  "Simulation": {
    "SlippagePips": 0.5,
    "RejectRate": 0.0,
    "RngSeed": 42
  },
  "Serilog": {
    "MinimumLevel": "Verbose",
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "File", "Args": { "path": "%SERILOG_FILE_PATH%", "rollingInterval": "Day" } }
    ]
  }
}
